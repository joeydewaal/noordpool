# Copy to backend/.env for local dev. Never commit the real .env.

DATABASE_URL="sqlite://./database.db"
JWT_SECRET="change-me-in-prod"
ADMIN_PASSWORD="Admin123"
NOORDPOOL_SEED=1

# Avatars: set R2_* to use Cloudflare R2; otherwise the backend uses the
# Local mode and writes uploads to AVATAR_DIR (served from /avatars).
AVATAR_DIR="./avatar-data"
PUBLIC_API_URL="http://localhost:3000"
# R2_ACCOUNT_ID=
# R2_BUCKET=noordpool-avatars
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Web Push (generate with `npx web-push generate-vapid-keys`)
VAPID_SUBJECT="mailto:you@example.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URL="http://localhost:3000/api/auth/google/callback"
FRONTEND_URL="http://localhost:5173"
