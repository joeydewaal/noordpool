# Copy to backend/.env for local dev. Never commit the real .env.

DATABASE_URL="sqlite://./database.db"
JWT_SECRET="change-me-in-prod"
ADMIN_PASSWORD="Admin123"
NOORDPOOL_SEED=1

# Comma-separated list of allowed CORS origins. Leave unset in dev for permissive CORS.
# ALLOWED_ORIGINS=https://noordpool.joeydewaal.com

# External base URL of this API. When set, avatar URLs are emitted as absolute
# https://<host>/avatars/<id>.webp so a cross-origin frontend can render them.
# PUBLIC_API_URL=https://api.noordpool.joeydewaal.com

# Web Push (generate with `npx web-push generate-vapid-keys`)
VAPID_SUBJECT="mailto:you@example.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URL="http://localhost:3000/api/auth/google/callback"
FRONTEND_URL="http://localhost:5173"
